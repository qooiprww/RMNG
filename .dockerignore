# Build context excludes. Root-anchored (leading `/`) where a path must survive at a
# deeper level — notably `/scripts/` (repo-root scripts: the host-only publish wrappers,
# never COPY'd into an image) vs `crates/control-server/scripts/` (guest scripts
# `include_str!`'d at compile time, MUST be in context).
#
# NOT excluded, load-bearing:
#   - gnome-patch/                     (template/Dockerfile's gnome-build stage compiles the
#                                       patched shell; the root Dockerfile no longer does)
#   - crates/control-server/scripts/   (include_str!'d guest scripts)
#   - template/setup/                  (the template Dockerfile's provisioning phase scripts)

# Rust build output (25G+; rebuilt in-stage with cache mounts)
target/
**/target/

# JS deps + build outputs (reinstalled/rebuilt in the bun stage)
node_modules/
**/node_modules/
frontend/build/

# Dev payload staging dir (plain clone-daemon / agent-wrapper / gnome-shell.deb for
# `cargo run` — assets.rs's dev fallback). The image build never consumes it (payloads
# are built in-stage), and staged binaries would add ~117MB to the context via COPY . .
crates/control-server/embedded-bin/

# VCS + tooling metadata
.git/
.gitignore
.dockerignore

# Docs / agent scaffolding — none of it is compiled or COPY'd
docs/
.superpowers/
.claude/

# Repo-root scripts (root-anchored so the CRATE-level crates/control-server/scripts/ dir —
# include_str!'d — survives). Host-only convenience wrappers (e.g. publish-template.sh):
# run on the host, never consumed by an image build, so they stay out of the context.
/scripts/

# Editor/OS cruft
*.tmp.*
*.swp
.DS_Store
